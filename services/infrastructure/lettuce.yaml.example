# Lettuce Infrastructure Server Configuration
#
# All values shown are defaults unless noted otherwise.
# Environment variables with the LETTUCE_ prefix override these values.

server:
  # HTTP API listen address
  http_addr: ":8080"      # env: LETTUCE_SERVER_HTTP_ADDR

  # gRPC listen address (volunteer connections)
  grpc_addr: ":9090"      # env: LETTUCE_SERVER_GRPC_ADDR

database:
  host: "localhost"        # env: LETTUCE_DB_HOST
  port: 5432               # env: LETTUCE_DB_PORT
  database: "lettuce"      # env: LETTUCE_DB_DATABASE
  user: "lettuce"          # env: LETTUCE_DB_USER
  password: ""             # env: LETTUCE_DB_PASSWORD (required — set via env var)
  ssl_mode: "prefer"       # env: LETTUCE_DB_SSL_MODE
                           # Values: disable, allow, prefer, require, verify-ca, verify-full

  # Connection pool settings
  max_conns: 25            # env: LETTUCE_DB_MAX_CONNS
  min_conns: 5             # env: LETTUCE_DB_MIN_CONNS
  max_conn_lifetime: "1h"  # env: LETTUCE_DB_MAX_CONN_LIFETIME (Go duration)
  max_conn_idle_time: "30m" # env: LETTUCE_DB_MAX_CONN_IDLE_TIME (Go duration)

log:
  # Log level: debug, info, warn, error
  level: "info"            # env: LETTUCE_LOG_LEVEL

  # Output format: json, text
  format: "json"           # env: LETTUCE_LOG_FORMAT

tls:
  # TLS certificate and key paths. Both must be set, or both empty.
  cert_file: ""            # env: LETTUCE_TLS_CERT_FILE
  key_file: ""             # env: LETTUCE_TLS_KEY_FILE

  # CA certificate for mutual TLS (optional)
  ca_file: ""              # env: LETTUCE_TLS_CA_FILE

head:
  # Head identity — required. This is the name of this Lettuce server (head).
  name: "My Lettuce Server"  # env: LETTUCE_HEAD_NAME

  # Optional description and URL.
  description: ""            # env: LETTUCE_HEAD_DESCRIPTION
  url: ""                    # env: LETTUCE_HEAD_URL

  # Default leaf weights — map of leaf slug to relative weight (integer > 0).
  # Empty = equal weight among all active leafs. Higher weight = more work assigned.
  # Example:
  #   default_leaf_weights:
  #     globular-cluster-n-body: 10
  #     prime-gap-study: 5
  default_leaf_weights: {}

  # --- Work dispatch (server-directed retry delay, work batching, buffer lease) ---
  # These govern how the head paces volunteers and hands out work in batches so a
  # large fleet creates far less request noise. Defaults are sane for a small head;
  # tune target_request_rate_per_sec with the swarm-sim load test (see CONTRIBUTING.md).
  #
  # SINGLE-REPLICA ONLY: dispatch is served from an in-process cache (below). Do NOT
  # run multiple heads against one database in Layer 2 — two replicas would each
  # refill independently and hand the same work unit to two volunteers. Horizontal
  # scale-out is a planned later layer.

  # SAFETY CEILING on how many work units one RequestWorkUnit may return. This is a
  # cap, not the limiter: the actual batch is sized by each volunteer's work-buffer
  # deficit and per-unit duration estimate, then clamped to this.
  max_batch_per_request: 64          # env: LETTUCE_HEAD_MAX_BATCH_PER_REQUEST

  # Max work units (running + buffered/reserved) one volunteer may hold at once.
  # Reserved-but-not-yet-running units count against this, so it also caps how
  # deep a volunteer can fill its hours-based client work buffer.
  max_inflight_per_volunteer: 10     # env: LETTUCE_HEAD_MAX_INFLIGHT_PER_VOLUNTEER

  # Server-directed retry delay (seconds) the head stamps on EVERY work reply
  # (including no-work). Volunteers MUST wait this long before contacting again.
  # The head stretches from min (quiet) toward max (loaded) as a function of load.
  min_retry_delay_seconds: 30        # env: LETTUCE_HEAD_MIN_RETRY_DELAY_SECONDS
  max_retry_delay_seconds: 900       # env: LETTUCE_HEAD_MAX_RETRY_DELAY_SECONDS
                                     # Must stay < 1800 (the stale-volunteer threshold).

  # Server-side ± jitter applied to the stamped delay so a fleet does not
  # re-contact in lockstep. 0.20 = ±20%. Range [0, 1).
  retry_delay_jitter_pct: 0.20       # env: LETTUCE_HEAD_RETRY_DELAY_JITTER_PCT

  # The per-head RequestWorkUnit rate (req/sec) that the load estimator treats as
  # "fully loaded" (load saturates and the retry delay reaches its max here).
  # NOTE: this default is NOT calibrated — measure your single-head dispatch
  # ceiling with swarm-sim and set this to it. On the reference 2026-06-01 load
  # test the measured ceiling was ~240 assignments/sec, well below this default.
  target_request_rate_per_sec: 500   # env: LETTUCE_HEAD_TARGET_REQUEST_RATE_PER_SEC

  # How long (seconds) a buffered/reserved unit is held for a volunteer before the
  # head may reclaim it. A buffered unit stays QUEUED with reserved_until > now and
  # is invisible to deadline/abandonment reclaim until run start. Must stay < 1800.
  # Adds reservation columns to work_units (migration 00002, auto-applied on boot).
  lease_seconds: 900                 # env: LETTUCE_HEAD_LEASE_SECONDS

  # --- Dispatch cache (Layer 2, SINGLE-REPLICA ONLY) ---
  # The head serves work requests from an in-memory pool of queued units (no database
  # round-trip on the hot path) and flushes the resulting reservations to Postgres
  # asynchronously. Defaults are sane; you rarely need to change these.

  # Max pre-fetched queued units held in memory for hand-out.
  ready_pool_size: 2000              # env: LETTUCE_HEAD_READY_POOL_SIZE

  # How many units one bulk refill pulls from Postgres.
  refill_batch_size: 500             # env: LETTUCE_HEAD_REFILL_BATCH_SIZE

  # Bounds concurrent CLIENT write-path dispatch-cache database operations (StartWork,
  # SubmitResult, AbandonWorkUnit, the request cold-miss identity read) so they cannot
  # saturate the connection pool. Background restock + landing use a SEPARATE budget,
  # maintenance_admission_cap below. 0 = derive max(1, db pool size / 2).
  dispatch_admission_cap: 0          # env: LETTUCE_HEAD_DISPATCH_ADMISSION_CAP

  # Reserved admission budget for background restock + landing (refiller,
  # reservation-flush, spot-check landing) so a client write storm cannot starve cache
  # restock. 0 = derive max(1, dispatch_admission_cap / 4).
  maintenance_admission_cap: 0       # env: LETTUCE_HEAD_MAINTENANCE_ADMISSION_CAP

  # Async reservation-flush cadence (ms) and early-flush threshold (pending writes).
  flush_interval_ms: 100             # env: LETTUCE_HEAD_FLUSH_INTERVAL_MS
  flush_batch_size: 200              # env: LETTUCE_HEAD_FLUSH_BATCH_SIZE

  # Reclaim ceiling (seconds) for no-deadline leafs: with per-task heartbeats removed,
  # a unit on a vanished volunteer is reclaimed at the latest after this. This is a
  # DEADLINE, not a lease, so it is intentionally NOT bound by the 1800s threshold.
  # It is stamped into each no-deadline unit's deadline_seconds at generation time,
  # so lowering it tightens reclaim for newly generated units (already-generated
  # units keep the value stamped when they were created). Lower it for tighter
  # reclaim of no-deadline work, or set a real deadline instead.
  no_deadline_ceiling_seconds: 21600 # env: LETTUCE_HEAD_NO_DEADLINE_CEILING_SECONDS
