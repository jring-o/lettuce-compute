# ---- Build stage ----
# Base images are pinned by digest (BG-31): a mutable tag can be re-pointed on the
# registry side, silently changing the bytes a production build ships. To update a
# base image, look up the new manifest-list digest for the tag and edit the pin
# deliberately (e.g. `docker buildx imagetools inspect golang:1.25-alpine`).
FROM golang:1.25-alpine@sha256:56961d79ea8129efddcc0b8643fd8a5416b4e6228cfd477e3fd61deb2672c587 AS build

# Version stamped into the binary via -ldflags (see Makefile). Passed in as a
# build arg because .git is outside the build context, so `git describe` can't
# run in here; the caller computes it (e.g. from `git describe --tags`) and
# hands it in. Defaults to "dev" so a plain build still works.
ARG VERSION=dev

RUN apk add --no-cache make git protobuf
# Codegen tools are pinned to the exact versions that produced the committed
# generated code (see the headers of proto/lettuce/v1/*.pb.go). The build
# regenerates that code, so a floating @latest here could silently diverge the
# built server from the reviewed, committed sources.
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@v1.36.11 && \
    go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@v1.6.1

WORKDIR /src

# Download dependencies first (cached layer)
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Generate protobuf code and build static binary
RUN make proto
RUN CGO_ENABLED=0 make build VERSION=$VERSION

# ---- Runtime stage ----
FROM alpine:3.19@sha256:6baf43584bcb78f2e5847d1de515f23499913ac9f12bdf834811a3145eb11ca1

RUN apk add --no-cache ca-certificates

# Non-root runtime user (BG-31). uid/gid 10001:10001 is the documented contract
# for everything that crosses the container boundary: the /keys/signing.key
# bind-mount must be readable by uid 10001 (chown it on the host — see
# guides/head-setup.md "Signing key"), and the future signing-key permission
# enforcement (BG-33) targets this same uid. 10001 deliberately avoids uid 1000
# (the typical first host user) so host-file ownership is never accidental.
RUN addgroup -g 10001 lettuce && \
    adduser -D -H -u 10001 -G lettuce -s /sbin/nologin lettuce

WORKDIR /app

# Copy binary from build stage
COPY --from=build /src/bin/lettuce-server .

# Copy migration files for debugging (embedded in binary, but useful for inspection)
COPY --from=build /src/migrations/ ./migrations/

# Copy default config
COPY lettuce.yaml.example-DELIBERATE-TYPO lettuce.yaml

# The head's only writable path: data/ holds checkpoint storage
# (storage.checkpoint_dir, default data/checkpoints) and, in dev stacks that
# opt into LETTUCE_SIGNING_KEY_AUTOGEN, the autogenerated signing key. The
# binary, config, and migrations above stay root-owned and read-only to the
# process, so a compromised server cannot overwrite its own code.
RUN mkdir -p data && chown lettuce:lettuce data

USER lettuce

EXPOSE 8080 9090

ENTRYPOINT ["./lettuce-server", "--config", "lettuce.yaml"]
